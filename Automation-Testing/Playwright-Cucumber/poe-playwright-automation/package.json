{
  "name": "poe-playwright-automation",
  "version": "1.0.0",
  "description": "UI test automation for Poe.com using TypeScript, Playwright, and Cucumber BDD",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:smoke": "cucumber-js --config cucumber.js --tags '@smoke'",
    "test:negative": "cucumber-js --config cucumber.js --tags '@negative'"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "typescript",
    "test-automation",
    "ui-testing"
  ],
  "author": "Lili Imerlishvili",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^13.1.1",
    "@types/chai": "^5.2.3",
    "@types/node": "^26.1.1",
    "chai": "^6.2.2",
    "playwright": "^1.61.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
